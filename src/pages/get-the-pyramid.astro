      { name: "Foster Sundry",                lat: 40.7021, lng: -73.9365 },
      { name: "Nook",                         lat: 40.7028, lng: -73.9352 },
      { name: "Saint Michel Cafe",            lat: 40.7021, lng: -73.9352 },
      { name: "L Train Vintage Thames",       lat: 40.7028, lng: -73.9352 },
      { name: "L Train Vintage St Nicholas",  lat: 40.7021, lng: -73.9352 },
      { name: "Molasses Books",               lat: 40.7021, lng: -73.9352 },
      { name: "Red Note Studios",             lat: 40.7058, lng: -73.9245 },
      { name: "LunÀtico",                     lat: 40.6862, lng: -73.9245 },
      { name: "MUD_RETURN",                   lat: 40.7295, lng: -73.9844 },
    ]

    function segDur(lat1, lng1, lat2, lng2) {
      const a = geoToPx(lat1, lng1), b = geoToPx(lat2, lng2)
      return Math.max(0.1, Math.hypot(b.x - a.x, b.y - a.y) / 80)
    }

    function ride(i) {
      const idx  = i % ROUTE.length
      const pidx = (i - 1 + ROUTE.length) % ROUTE.length
      const curr = ROUTE[idx], prev = ROUTE[pidx]
      const proxy = { lat: bikerLat, lng: bikerLng }

      if (curr.name === 'BOAT') {
        bikerMoving = true
        gsap.to(proxy, {
          lat: curr.lat, lng: curr.lng,
          duration: segDur(prev.lat, prev.lng, curr.lat, curr.lng),
          ease: 'none',
          onUpdate() { bikerLat = proxy.lat; bikerLng = proxy.lng },
          onComplete() {
            bikerLat = curr.lat; bikerLng = curr.lng
            bikerMoving = false
            clearTrail()
            const nextIdx = (i + 1) % ROUTE.length
            ferryTo(ROUTE[nextIdx], () => ride(i + 2))
          }
        })
        return
      }

      bikerMoving = true
      gsap.to(proxy, {
        lat: curr.lat, lng: curr.lng,
        duration: segDur(prev.lat, prev.lng, curr.lat, curr.lng),
        ease: 'none',
        onUpdate() { bikerLat = proxy.lat; bikerLng = proxy.lng },
        onComplete() {
          bikerLat = curr.lat; bikerLng = curr.lng
          bikerMoving = false
          clearTrail()
          gsap.delayedCall(1, () => ride(i + 1))
        }
      })
    }
    ride(1)

    gsap.to(bk.querySelector('#bk-rw'), { rotation:360, svgOrigin:'14 56', duration:1.4, ease:'none', repeat:-1 })
    gsap.to(bk.querySelector('#bk-fw'), { rotation:360, svgOrigin:'65 56', duration:1.4, ease:'none', repeat:-1 })
    ;[['#bk-n1',0],['#bk-n2',0.5],['#bk-n3',1.0]].forEach(([sel,delay]) => {
      const el = bk.querySelector(sel)
      gsap.timeline({ delay, repeat:-1, repeatDelay:0.8 })
        .set(el, { y:0, opacity:0 })
        .to(el, { opacity:1, duration:0.15 })
        .to(el, { y:-16, opacity:0, duration:1.0, ease:'power1.out' })
    })
  </script>

