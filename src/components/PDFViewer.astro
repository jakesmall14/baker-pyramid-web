---
import regionsData from '../../regions.json';

interface Resource {
  name: string;
  url: string;
  expandToLine?: boolean;
}
interface Brand {
  name: string;
}
interface Region {
  title: string;
  url: string;
  rx: number;
  ry: number;
  rw: number;
  rh: number;
}
interface Props {
  pdfUrl: string;
  issueNum: number;
  resources: Resource[];
  brands: Brand[];
}
const { pdfUrl, issueNum, resources, brands } = Astro.props;
const issueRegions: Region[] = (regionsData as Record<string, Region[]>)[String(issueNum)] ?? [];
---

<div class="pdf-viewer-wrap">
  <div
    id="pdf-viewer"
    data-pdf-url={pdfUrl}
    data-resources={JSON.stringify(resources)}
    data-brands={JSON.stringify(brands)}
    data-regions={JSON.stringify(issueRegions)}
  >
    <div class="pdf-loading">Loading issue {issueNum}…</div>
  </div>
</div>

<script>
  import { getDocument, GlobalWorkerOptions, Util } from 'pdfjs-dist';

  GlobalWorkerOptions.workerSrc = '/pdf.worker.min.mjs';

  interface Resource { name: string; url: string; expandToLine?: boolean }
  interface Brand { name: string }
  interface Region { title: string; url: string; rx: number; ry: number; rw: number; rh: number }
  interface Char { char: string; x: number; y: number; w: number; h: number }

  const viewer = document.getElementById('pdf-viewer')!;
  const pdfUrl = viewer.dataset.pdfUrl!;
  const resources: Resource[] = JSON.parse(viewer.dataset.resources!);
  const brands: Brand[] = JSON.parse(viewer.dataset.brands!);
  const regions: Region[] = JSON.parse(viewer.dataset.regions!);

  let pdfCache: any = null;
  let renderController: AbortController | null = null;
  let resizeTimer: ReturnType<typeof setTimeout>;

  async function getPdf() {
    if (!pdfCache) pdfCache = await getDocument(pdfUrl).promise;
    return pdfCache;
  }

  async function renderAll() {
    if (renderController) renderController.abort();
    renderController = new AbortController();
    const { signal } = renderController;

    const pdf = await getPdf();
    const containerWidth = document.documentElement.clientWidth;
    viewer.innerHTML = '';

    for (let i = 1; i <= pdf.numPages; i++) {
      if (signal.aborted) return;
      const page = await pdf.getPage(i);
      const wrap = await renderPage(page, containerWidth, signal);
      if (signal.aborted) return;
      viewer.appendChild(wrap);
    }
  }

  async function renderPage(page: any, containerWidth: number, signal: AbortSignal) {
    const pixelRatio = window.devicePixelRatio || 1;
    const unscaled = page.getViewport({ scale: 1 });
    const scale = containerWidth / unscaled.width;
    const viewport = page.getViewport({ scale });

    const wrap = document.createElement('div');
    wrap.className = 'pdf-page-wrap';
    wrap.style.height = viewport.height + 'px';

    const canvas = document.createElement('canvas');
    canvas.width = Math.floor(containerWidth * pixelRatio);
    canvas.height = Math.floor(viewport.height * pixelRatio);
    canvas.style.width = containerWidth + 'px';
    canvas.style.height = viewport.height + 'px';

    const ctx = canvas.getContext('2d')!;
    ctx.scale(pixelRatio, pixelRatio);
    const renderTask = page.render({ canvasContext: ctx, viewport });
    signal.addEventListener('abort', () => renderTask.cancel(), { once: true });
    try {
      await renderTask.promise;
    } catch {
      return wrap;
    }
    wrap.appendChild(canvas);

    const overlay = document.createElement('div');
    overlay.className = 'pdf-link-overlay';
    wrap.appendChild(overlay);

    const textContent = await page.getTextContent();
    const chars = buildCharMap(textContent, viewport, scale);
    const fullText = chars.map((c) => c.char).join('');

    // Pass 1: named resources (exact matches with optional line expansion)
    const linkedRanges: [number, number][] = [];
    placeLinks(overlay, chars, fullText, resources, linkedRanges, (r) => r.url, (r) => r.expandToLine);

    // Pass 2: brand auto-links (only where not already linked)
    placeLinks(
      overlay,
      chars,
      fullText,
      brands,
      linkedRanges,
      (b) => `https://www.google.com/search?q=${encodeURIComponent(b.name)}`,
      () => false
    );

    // Pass 3: coordinate-based image/logo regions
    placeRegions(overlay, regions, viewport);

    return wrap;
  }

  function buildCharMap(textContent: any, viewport: any, scale: number): Char[] {
    const items = (textContent.items as any[]).filter((i) => 'str' in i && i.str.length > 0);
    const chars: Char[] = [];

    for (let k = 0; k < items.length; k++) {
      const item = items[k];
      const [cx, cy] = Util.applyTransform(
        [item.transform[4], item.transform[5]],
        viewport.transform
      );
      const fontH = Math.abs(item.transform[3]) * scale;
      const itemW = item.width * scale;
      const charW = item.str.length > 0 ? itemW / item.str.length : 0;

      // Synthetic inter-word space when there's a horizontal gap on the same line
      if (k > 0 && chars.length > 0) {
        const prev = chars[chars.length - 1];
        const yDiff = Math.abs((cy - fontH) - prev.y);
        if (yDiff < fontH * 0.6 && cx > prev.x + prev.w + charW * 0.25) {
          chars.push({ char: ' ', x: prev.x + prev.w, y: cy - fontH, w: cx - (prev.x + prev.w), h: fontH });
        }
      }
      for (let i = 0; i < item.str.length; i++) {
        chars.push({ char: item.str[i], x: cx + i * charW, y: cy - fontH, w: charW, h: fontH });
      }
    }
    return chars;
  }

  function placeLinks<T extends { name: string }>(
    overlay: HTMLElement,
    chars: Char[],
    fullText: string,
    entries: T[],
    linkedRanges: [number, number][],
    getUrl: (entry: T) => string,
    getExpand: (entry: T) => boolean | undefined
  ) {
    for (const entry of entries) {
      const name = entry.name;
      let from = 0;
      while (true) {
        const idx = fullText.indexOf(name, from);
        if (idx === -1) break;

        const end = idx + name.length;

        // Skip if this range overlaps an already-linked range
        const overlaps = linkedRanges.some(([s, e]) => idx < e && end > s);
        if (overlaps) { from = end; continue; }

        const matchChars = chars.slice(idx, end);
        let x1 = Math.min(...matchChars.map((c) => c.x));
        let x2 = Math.max(...matchChars.map((c) => c.x + c.w));
        const y1 = Math.min(...matchChars.map((c) => c.y));
        const maxH = Math.max(...matchChars.map((c) => c.h));

        if (getExpand(entry)) {
          const tol = maxH * 0.6;
          for (let i = idx - 1; i >= 0; i--) {
            if (Math.abs(chars[i].y - y1) <= tol) x1 = Math.min(x1, chars[i].x);
            else break;
          }
          for (let i = end; i < chars.length; i++) {
            if (Math.abs(chars[i].y - y1) <= tol) x2 = Math.max(x2, chars[i].x + chars[i].w);
            else break;
          }
        }

        const a = document.createElement('a');
        a.href = getUrl(entry);
        a.target = '_blank';
        a.rel = 'noopener noreferrer';
        a.title = name;
        a.style.left = x1 + 'px';
        a.style.top = y1 + 'px';
        a.style.width = (x2 - x1) + 'px';
        a.style.height = maxH * 1.15 + 'px';
        overlay.appendChild(a);

        linkedRanges.push([idx, end]);
        from = end;
      }
    }
  }

  function placeRegions(overlay: HTMLElement, regs: Region[], viewport: any) {
    for (const r of regs) {
      const a = document.createElement('a');
      a.href = r.url;
      a.target = '_blank';
      a.rel = 'noopener noreferrer';
      a.title = r.title;
      a.style.left = (r.rx * viewport.width) + 'px';
      a.style.top = (r.ry * viewport.height) + 'px';
      a.style.width = (r.rw * viewport.width) + 'px';
      a.style.height = (r.rh * viewport.height) + 'px';
      overlay.appendChild(a);
    }
  }

  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(renderAll, 350);
  });

  renderAll().catch(console.error);
</script>
