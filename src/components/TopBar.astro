---
import { getLatestIssue } from '../utils/issues.js'
const latest = getLatestIssue()
---

<header id="topbar">
  <div class="topbar-inner">

    <!-- Left: pin icon + desktop nav links -->
    <div class="topbar-left">
      <a href="/get-the-pyramid" class="topbar-pin" aria-label="Map — Get the Pyramid">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20"
             fill="none" stroke="currentColor" stroke-width="1.5"
             stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
          <circle cx="12" cy="9" r="2.5"/>
        </svg>
      </a>
      <span class="topbar-dlinks">
        <a href="/get-the-pyramid">Get the Pyramid</a>
        <span class="topbar-sep"> | </span>
        <a href={latest.url} target="_blank" rel="noopener noreferrer">Print Today's Pyramid</a>
      </span>
    </div>

    <!-- Center: wordmark image -->
    <a href="/" class="topbar-logo-link" aria-label="The Baker Pyramid — home">
      <img src="/topbar/topbaricon.png" alt="The Baker Pyramid" class="topbar-logo-img" />
    </a>

    <!-- Right: desktop nav links + Instagram -->
    <div class="topbar-right">
      <span class="topbar-dlinks">
        <button class="topbar-modal-btn" data-modal="modal-archive">All Prior Pyramids</button>
        <span class="topbar-sep"> | </span>
        <button class="topbar-modal-btn" data-modal="modal-music">Open Mic Cal</button>
        <span class="topbar-sep"> | </span>
      </span>
      <a
        href="https://www.instagram.com/thebakerpyramid"
        class="topbar-ig"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="The Baker Pyramid on Instagram"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <circle cx="12" cy="12" r="4.5"/>
          <circle cx="17.4" cy="6.6" r="0.6" fill="currentColor" stroke="none"/>
        </svg>
      </a>
    </div>

  </div>
</header>
