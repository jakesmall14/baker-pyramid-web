---
import calendar from '../../calendar.json';

interface Issue {
  num: number;
  filename: string;
  url: string;
}

interface Props {
  issues: Issue[];
  latestIssueUrl: string;
}

const { issues, latestIssueUrl } = Astro.props;
const reversedIssues = [...issues].reverse();

const DAYS = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'] as const;
---

<!-- BOTTOM BAR -->
<footer id="bottom-bar">
  <nav class="bottom-bar-nav">
    <a class="bottom-bar-btn" href={latestIssueUrl} target="_blank" rel="noopener noreferrer">
      Print Today's Pyramid
    </a>
    <span class="bottom-bar-sep">✸</span>
    <button class="bottom-bar-btn" data-modal="modal-archive">All Prior Pyramids</button>
    <span class="bottom-bar-sep">✸</span>
    <button class="bottom-bar-btn" data-modal="modal-music">Play More Music in New York</button>
    <span class="bottom-bar-sep">✸</span>
    <button class="bottom-bar-btn" data-modal="modal-about">About</button>
    <span class="bottom-bar-sep">✸</span>
    <a class="bottom-bar-btn" href="https://www.instagram.com/thebakerpyramid" target="_blank" rel="noopener noreferrer">Instagram</a>
    <span class="bottom-bar-sep">✸</span>
    <button class="bottom-bar-btn" data-modal="modal-signup">Sign Up for Pyramid Dropoffs</button>
  </nav>
  <div class="bottom-bar-tm">The Baker Pyramid &copy; 2026 &middot; NYC &middot; All Rights Reserved.</div>
</footer>

<!-- ALL PRIOR PYRAMIDS MODAL (full-screen) -->
<div id="modal-archive" class="modal-backdrop" role="dialog" aria-modal="true" aria-label="All Prior Pyramids">
  <div class="modal-box modal-box--archive">
    <div class="modal-archive-header">
      <div class="modal-title" style="border:none;margin:0;padding:0;">All Prior Pyramids</div>
      <button class="modal-close" data-close="modal-archive">Close ×</button>
    </div>
    <div class="archive-thumb-grid" id="archive-thumb-grid">
      {reversedIssues.map((issue) => (
        <div class="archive-thumb-cell" data-pdf-url={issue.url} data-issue-num={issue.num}>
          <div class="archive-thumb-placeholder">{issue.num}</div>
          <div class="archive-thumb-label">Issue {issue.num}</div>
        </div>
      ))}
    </div>
  </div>
</div>

<!-- PDF FULL-SCREEN VIEW MODAL -->
<div id="modal-pdf-view" class="modal-backdrop" role="dialog" aria-modal="true" aria-label="Issue viewer">
  <div class="modal-pdf-box">
    <div class="modal-pdf-topbar">
      <button id="back-to-archive">← All Prior Pyramids</button>
      <span class="modal-pdf-label" id="pdf-view-label"></span>
    </div>
    <iframe id="pdf-frame" src="" title="Issue PDF"></iframe>
  </div>
</div>

<!-- PLAY MORE MUSIC IN NEW YORK MODAL -->
<div id="modal-music" class="modal-backdrop" role="dialog" aria-modal="true" aria-label="Play More Music in New York">
  <div class="modal-box">
    <button class="modal-close" data-close="modal-music">Close ×</button>
    <div class="modal-title">Play More Music in New York</div>

    <!-- Day tabs -->
    <div class="music-day-tabs" id="music-day-tabs">
      {DAYS.map((day, i) => (
        <>
          <button class="day-tab" data-day={day}>
            {day.slice(0, 3)}
          </button>
          {i < DAYS.length - 1 && <span class="day-tab-sep">|</span>}
        </>
      ))}
    </div>

    <!-- All entries — JS filters by day -->
    <ul class="calendar-list" id="calendar-list">
      {calendar.map((entry) => (
        <li class="calendar-item" data-day={entry.day}>
          <div class="calendar-venue">
            {entry.url
              ? <a href={entry.url} target="_blank" rel="noopener noreferrer" style="color:inherit;text-decoration:none;">{entry.venue}</a>
              : entry.venue
            }
          </div>
          <div class="calendar-event">{entry.event}</div>
          <div class="calendar-time">{entry.time}{entry.info ? ` — ${entry.info}` : ''}</div>
        </li>
      ))}
    </ul>

    <p class="calendar-none" id="calendar-none" style="display:none;">No listings for this day.</p>
  </div>
</div>

<!-- ABOUT MODAL -->
<div id="modal-about" class="modal-backdrop" role="dialog" aria-modal="true" aria-label="About">
  <div class="modal-box">
    <button class="modal-close" data-close="modal-about">Close ×</button>
    <div class="modal-title">About</div>
    <div class="about-body">
      <p>The Baker Pyramid — read it, or ash your cigarette out on it. We cover music and art in New York City.</p>
    </div>
  </div>
</div>

<!-- SIGN UP FOR PYRAMID DROPOFFS MODAL -->
<div id="modal-signup" class="modal-backdrop modal-backdrop--fullscreen" role="dialog" aria-modal="true" aria-label="Sign Up for Pyramid Dropoffs">
  <div class="modal-signup-box">
    <div class="modal-signup-header">
      <div class="modal-signup-title">Sign Up for Pyramid Dropoffs</div>
      <button class="modal-close" data-close="modal-signup" style="position:static;">Close ×</button>
    </div>
    <iframe
      id="signup-frame"
      src="https://docs.google.com/forms/d/e/1FAIpQLSd2f7abla2soyyVLUfq4yyoTJQaFvtyLP7zKmfJcRk2jR0qZQ/viewform?embedded=true"
      title="Sign Up for Pyramid Dropoffs"
      frameborder="0"
      marginheight="0"
      marginwidth="0"
    >Loading…</iframe>
  </div>
</div>

<script>
  import { getDocument, GlobalWorkerOptions } from 'pdfjs-dist';

  GlobalWorkerOptions.workerSrc = '/pdf.worker.min.mjs';

  // ── Modal helpers ──────────────────────────────────────
  function openModal(id: string) {
    document.getElementById(id)?.classList.add('open');
  }
  function closeModal(id: string) {
    document.getElementById(id)?.classList.remove('open');
  }

  document.querySelectorAll<HTMLButtonElement>('[data-modal]').forEach((btn) => {
    btn.addEventListener('click', () => openModal(btn.dataset.modal!));
  });

  document.querySelectorAll<HTMLButtonElement>('[data-close]').forEach((btn) => {
    btn.addEventListener('click', () => closeModal(btn.dataset.close!));
  });

  document.querySelectorAll<HTMLElement>('.modal-backdrop').forEach((backdrop) => {
    backdrop.addEventListener('click', (e) => {
      if (e.target === backdrop) backdrop.classList.remove('open');
    });
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      document.querySelectorAll('.modal-backdrop.open').forEach((m) => m.classList.remove('open'));
    }
  });

  // ── Music day tabs ─────────────────────────────────────
  const ALL_DAYS = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
  const dayTabs = document.querySelectorAll<HTMLButtonElement>('.day-tab');
  const calItems = document.querySelectorAll<HTMLLIElement>('#calendar-list .calendar-item');
  const noneMsg = document.getElementById('calendar-none')!;

  function selectDay(day: string) {
    dayTabs.forEach(t => t.classList.toggle('active', t.dataset.day === day));
    let visible = 0;
    calItems.forEach(item => {
      const show = item.dataset.day === day;
      (item as HTMLElement).style.display = show ? '' : 'none';
      if (show) visible++;
    });
    noneMsg.style.display = visible === 0 ? '' : 'none';
  }

  dayTabs.forEach(tab => {
    tab.addEventListener('click', () => selectDay(tab.dataset.day!));
  });

  // Re-default to today each time the music modal opens
  const musicModal = document.getElementById('modal-music')!;
  new MutationObserver(() => {
    if (musicModal.classList.contains('open')) {
      selectDay(ALL_DAYS[new Date().getDay()]);
    }
  }).observe(musicModal, { attributes: true, attributeFilter: ['class'] });

  // Set initial state immediately
  selectDay(ALL_DAYS[new Date().getDay()]);

  // ── Archive thumbnail lazy rendering ───────────────────
  const grid = document.getElementById('archive-thumb-grid')!;
  const archiveModal = document.getElementById('modal-archive')!;
  let thumbsInited = false;

  new MutationObserver(() => {
    if (archiveModal.classList.contains('open') && !thumbsInited) {
      thumbsInited = true;
      initThumbs();
    }
  }).observe(archiveModal, { attributes: true, attributeFilter: ['class'] });

  function initThumbs() {
    const cells = grid.querySelectorAll<HTMLElement>('.archive-thumb-cell');
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const cell = entry.target as HTMLElement;
          io.unobserve(cell);
          renderThumb(cell);
        });
      },
      { root: grid, rootMargin: '300px', threshold: 0 }
    );
    cells.forEach((cell) => { if (!cell.dataset.rendered) io.observe(cell); });
  }

  async function renderThumb(cell: HTMLElement) {
    if (cell.dataset.rendered) return;
    cell.dataset.rendered = 'true';
    const pdfUrl = cell.dataset.pdfUrl!;
    try {
      const pdf = await getDocument(pdfUrl).promise;
      const page = await pdf.getPage(1);
      const cellWidth = cell.offsetWidth || 320;
      const pixelRatio = window.devicePixelRatio || 1;
      const unscaled = page.getViewport({ scale: 1 });
      const scale = cellWidth / unscaled.width;
      const viewport = page.getViewport({ scale });
      const canvas = document.createElement('canvas');
      canvas.width = Math.floor(cellWidth * pixelRatio);
      canvas.height = Math.floor(viewport.height * pixelRatio);
      canvas.style.width = cellWidth + 'px';
      canvas.style.height = viewport.height + 'px';
      const ctx = canvas.getContext('2d')!;
      ctx.scale(pixelRatio, pixelRatio);
      await page.render({ canvasContext: ctx, viewport }).promise;
      cell.querySelector('.archive-thumb-placeholder')?.replaceWith(canvas);
    } catch (err) {
      console.warn(`Thumb render failed for ${cell.dataset.issueNum}:`, err);
    }
  }

  // ── PDF view modal ─────────────────────────────────────
  const pdfFrame = document.getElementById('pdf-frame') as HTMLIFrameElement;
  const pdfViewLabel = document.getElementById('pdf-view-label')!;

  grid.querySelectorAll<HTMLElement>('.archive-thumb-cell').forEach((cell) => {
    cell.addEventListener('click', () => {
      pdfFrame.src = cell.dataset.pdfUrl!;
      pdfViewLabel.textContent = `Issue ${cell.dataset.issueNum}`;
      closeModal('modal-archive');
      openModal('modal-pdf-view');
    });
  });

  document.getElementById('back-to-archive')?.addEventListener('click', () => {
    closeModal('modal-pdf-view');
    pdfFrame.src = '';
    openModal('modal-archive');
  });
</script>
