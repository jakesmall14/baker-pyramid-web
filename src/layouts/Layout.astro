---
import '../styles/global.css';
import TopBar from '../components/TopBar.astro';
import BottomBar from '../components/BottomBar.astro';
import { getIssues, getLatestIssue } from '../utils/issues.js';

interface Props {
  title?: string;
}

const { title = 'The Baker Pyramid' } = Astro.props;
const issues = getIssues();
const latest = getLatestIssue();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="The Baker Pyramid — free, independent NYC culture newspaper." />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/icon/webicon.png" />
  </head>
  <body>
    <TopBar />
    <main id="main">
      <slot />
    </main>
    <BottomBar issues={issues} latestIssueUrl={latest.url} />
  </body>
</html>
